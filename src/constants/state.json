{
  "canvas": {
    "width": 450,
    "height": 450,
    "watermark": true,
    "aspect-ratio": "1:1",
    "source": "/images/glow-wallpaper.jpg"
  },
  "code": {
    "padding": 20,
    "editable": true,
    "draggable": false,
    "translucent": true,
    "line-numbers": false,
