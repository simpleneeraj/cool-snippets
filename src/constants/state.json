    "type": "windows::terminal",
    "input": "nothing",
    "position": "nothing",
    "colors": [
      {
        "name": "Red",
        "hex": "#fd4539"
      },
      {
        "name": "Yellow",
        "hex": "#ffd213"
      },
      {
        "name": "Green",
        "hex": "#21d854"
      }
    ],
    "background": "rgba(0, 0, 0, 0.75)",
